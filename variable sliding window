#include <iostream>
#include <vector>
#include <algorithm>

using namespace std;

#define all(v) v.begin(), v.end()

void Magek() {
    int n;
    cin >> n;
    
    vector<int> v(n);
    for (int i = 0; i < n; i++) {
        cin >> v[i];
    }
    
    sort(all(v));
    
    int l = 0, r = 0;
    // r-l
    int ans = 0;
    
    while (r < n) {
        while (v[r] - v[l] > 5) {
            ans = max(r - l, ans);
            l++;
        }
        r++;
    }
    
    ans = max(r - l, ans);
    cout << ans << endl;
}
